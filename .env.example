NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Comma-separated browser origins (web). Mobile clients often omit Origin and are still allowed.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Postgres — Supabase: Settings → Database → Connection string (Transaction pooler recommended)
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# Supabase — Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Dashboard: Settings → API → Secret key (formerly service_role) — never expose to clients
SUPABASE_SERVICE_ROLE_KEY=your-secret-key
# JWT verification uses the JWKS endpoint (SUPABASE_URL/auth/v1/.well-known/jwks.json) — no secret needed

# One-time seed (pnpm run seed:platform-admin) after migrations — not used at runtime
PLATFORM_ADMIN_EMAIL=you@example.com
PLATFORM_ADMIN_PASSWORD=
